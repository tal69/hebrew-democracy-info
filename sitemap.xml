---
layout: null
permalink: /sitemap.xml
---
<?xml version="1.0" encoding="UTF-8"?>
<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9">
  <url>
    <loc>{{ "/" | absolute_url }}</loc>
    <lastmod>{{ site.data.site.lastUpdated }}</lastmod>
    <changefreq>daily</changefreq>
    <priority>1.0</priority>
  </url>
  {% for topic in site.data.topics.topics %}
  <url>
    <loc>{{ topic.page | absolute_url }}</loc>
    <lastmod>{{ site.data.site.lastUpdated }}</lastmod>
    <changefreq>weekly</changefreq>
    <priority>0.9</priority>
  </url>
  {% endfor %}
  {% assign papers = site.papers | sort: "sortKey" | reverse %}
  {% for paper in papers %}
  <url>
    <loc>{{ paper.url | absolute_url }}</loc>
    <lastmod>{{ paper.dateModified }}</lastmod>
    <changefreq>monthly</changefreq>
    <priority>0.8</priority>
  </url>
  {% endfor %}
  <url>
    <loc>{{ "/accessibility.html" | absolute_url }}</loc>
    <lastmod>{{ site.data.site.lastUpdated }}</lastmod>
    <changefreq>yearly</changefreq>
    <priority>0.4</priority>
  </url>
</urlset>
